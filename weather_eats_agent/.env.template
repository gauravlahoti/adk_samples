GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=<your-gcp-project-id>
GOOGLE_CLOUD_LOCATION=<gcp-region e.g. us-central1>

MODEL=<gemini-model e.g. gemini-2.5-flash-lite>
GOOGLE_MAPS_API_KEY=<your-google-maps-api-key>
MAPS_MCP_URL=<google-maps-mcp-endpoint-url>

# Email configuration (required - via Resend MCP HTTP server)
RESEND_MCP_URL=<your-resend-mcp-server-url e.g. https://resend-mcp-server-xxxxx.run.app/mcp>
RESEND_API_KEY=<your-resend-api-key>
SENDER_EMAIL_ADDRESS=<your-verified-sender-email>
